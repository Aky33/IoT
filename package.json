{
  "name": "iot-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "IoT care assistance button — monorepo.",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "setup": "npm run setup --workspace @iot/backend",
    "start": "npm run start --workspace @iot/backend",
    "dev": "npm run dev --workspace @iot/backend",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspace @iot/backend",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:up": "npm run db:up --workspace @iot/backend",
    "db:down": "npm run db:down --workspace @iot/backend",
    "db:logs": "npm run db:logs --workspace @iot/backend"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2"
  }
}
