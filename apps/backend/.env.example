# Server
PORT=3000
NODE_ENV=development

# MongoDB host port (container port is always 27017 internally).
# Change this if 27019 is taken on your machine.
MONGO_HOST_PORT=27019
MONGO_DB_NAME=iot-care

# Optional override — takes precedence over MONGO_HOST_PORT / MONGO_DB_NAME.
# Leave empty for local Docker; set for Atlas / authenticated connections.
MONGODB_URI=
